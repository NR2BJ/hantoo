# ============================================
# Hantoo - 최소 설정 파일
# ============================================
# 이 파일에는 인프라 설정만 포함됩니다.
# JWT, 암호화 키, KIS/LLM API 키, 관리자 계정 등
# 모든 앱 설정은 웹 UI에서 관리됩니다.
# ============================================

# PostgreSQL 비밀번호 (Docker Compose에서 사용)
DB_PASSWORD=changeme_strong_password

# Caddy 도메인 (외부 노출 시 실제 도메인으로 변경)
# 예: hantoo.yourdomain.com
DOMAIN=localhost
