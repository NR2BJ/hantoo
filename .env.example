# Database
DB_PASSWORD=changeme_strong_password
DATABASE_URL=postgresql+asyncpg://hantoo:${DB_PASSWORD}@postgres:5432/hantoo

# Redis
REDIS_URL=redis://redis:6379/0

# Auth
JWT_SECRET=changeme_generate_with_openssl_rand_hex_32
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=1440

# Encryption key for KIS credentials (generate: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())")
ENCRYPTION_KEY=changeme_generate_fernet_key

# KIS API
KIS_PROD_BASE_URL=https://openapi.koreainvestment.com:9443
KIS_PAPER_BASE_URL=https://openapivts.koreainvestment.com:29443
KIS_WS_URL=ws://ops.koreainvestment.com:21000
KIS_WSS_URL=wss://ops.koreainvestment.com:21000

# LLM
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
DEFAULT_LLM_PROVIDER=claude

# Caddy / Domain
DOMAIN=localhost

# Security
REQUIRE_2FA=true
LOGIN_RATE_LIMIT=5/minute
ALLOWED_IPS=

# Admin (first user created on startup)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=changeme_admin_password
